PULSAR_TOPIC=repos.raw
PULSAR_CLIENT_IMAGE="[your Docker image here]"
CRAWLER_MAX_BACKLOG=1000
CRAWLER_BACKLOG_SLEEP_SECONDS=30

# Crawler run shape. Use CRAWL_DAYS=1 for smoke tests.
CRAWL_DAYS=150
CRAWL_DATE_FIELD=created-or-pushed
PARTITION_TOKENS=false
CRAWLER_BACKLOG_ENABLED=true

# Analytics consumer: derived topics and run shape.
ENRICHED_TOPIC=repos.enriched
AGGREGATE_TOPIC=repos.aggregates
FLUSH_IDLE_SECONDS=30
ANALYTICS_SUBSCRIPTION=analytics-q1-q4
AGGREGATOR_SUBSCRIPTION=analytics-aggregator
ANALYTICS_NUM_RUNNERS=8
TOP_N=10
FLUSH_EVERY=100
ENRICH_GITHUB=true

# Optional token pool. Any variable starting with GITHUB_TOKEN is used.
# Copy this file to .env and replace placeholders with your own tokens.
GITHUB_TOKEN_1="[your GitHub token here]"
GITHUB_TOKEN_2="[your GitHub token here]"
GITHUB_TOKEN_3="[your GitHub token here]"
GITHUB_TOKEN_4="[your GitHub token here]"
GITHUB_TOKEN_5="[your GitHub token here]"
