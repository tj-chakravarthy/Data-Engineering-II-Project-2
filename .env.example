# Copy to .env and set your GitHub token locally.
# Do not commit .env or real tokens.

GITHUB_TOKEN_1=[your GitHub token here]
PULSAR_SERVICE_URL=pulsar://pulsar:6650
PULSAR_TOPIC=repos.raw
PULSAR_SUBSCRIPTION=debug-consumer
CRAWLER_IMAGE=andreashadjoullis1153/crawler:latest

# Crawler run shape. Use CRAWL_DAYS=1 for smoke tests.
CRAWL_DAYS=1
CRAWL_DATE_FIELD=created-or-pushed

# Optional token pool. Any variable starting with GITHUB_TOKEN is used.
# GITHUB_TOKEN=[your GitHub token here]
# GITHUB_TOKEN_2=[your GitHub token here]
# GITHUB_TOKEN_3=[your GitHub token here]
# GITHUB_TOKEN_4=[your GitHub token here]
# GITHUB_TOKEN_5=[your GitHub token here]

# OpenStack / SSC variables.
# Used by the infrastructure owner for VM provisioning and by teammates who
# need to inspect or run services on the course cloud environment.
#
# OS_USERNAME and OS_PASSWORD are per-user secrets. Fill these in locally only.

OS_USERNAME=
OS_PASSWORD=
